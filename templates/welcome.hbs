<div class="ctm-onboarding-frame">
  <div class="ctm-onboarding">
    <p class="ctm-onboarding-lead">{{localize "CTM.Onboarding.Intro"}}</p>
    <div class="ctm-control-path ctm-onboarding-path" aria-label="{{localize "CTM.Onboarding.OpenPath"}}">
      <span><i class="{{tokenControlsIcon}}" aria-hidden="true"></i>{{localize "CTM.Help.Opening.Controls"}}</span>
      <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
      <span><i class="{{spotlightControlIcon}}" aria-hidden="true"></i>{{localize "CTM.Help.Opening.Button"}}</span>
    </div>
    {{#if isGM}}
      <p>{{localize "CTM.Onboarding.GMBody"}}</p>
    {{else}}
      <p>{{localize "CTM.Onboarding.PlayerBody"}}</p>
    {{/if}}
    <label class="ctm-onboarding-skip">
      <input type="checkbox" name="skipWelcome">
      <span>{{localize "CTM.Onboarding.DontShowAgain"}}</span>
    </label>
  </div>

  <footer class="form-footer ctm-onboarding-actions">
    <button type="button" data-action="openSpotlight">
      <i class="{{spotlightControlIcon}}" aria-hidden="true"></i>
      <span>{{localize "CTM.Onboarding.OpenWindow"}}</span>
    </button>
    <button type="button" data-action="dismiss">
      <span>{{localize "CTM.Onboarding.NotNow"}}</span>
    </button>
  </footer>
</div>
